info.onCountdownEnd(function () {
    if (camera_lighting) {
        camera_lighting = false
        sprites.destroy(black_screen)
        if (steve.x == 90) {
            timer.after(1000, function () {
                mistimedCamera()
            })
        } else if (steve.overlapsWith(overlap_check) && steve.x == -49) {
            timedCamera()
        }
    } else {
        dead = true
        info.stopCountdown()
        music.stopAllSounds()
        music.play(music.createSong(hex``), music.PlaybackMode.InBackground)
