Box.setPosition(92, 95)
index = 0
text_list = [
"You know how to hack, right?",
"It is you, after all...",
"who's cracking open the safe.",
"If you must be reminded,",
"then here's what you need to know.",
"There are three sections.",
"Press \"B\" to move between them.",
"Section One, you are a green dot.",
"Use WASD to move.",
"Avoid the green barrier.",
"Collect all the red dots.",
"Section Two, you are a purple dot.",
"Use A and D to move left and right.",
"Press \"A\" to jump.",
"Click \"A\" a lot on a wall to climb.",
"There are gates blocking your path-",
"Collect keys to unlock them.",
"This also applies to Section One.",
"Section Three, you are a blue dot.",
"Use WASD to move.",
"Avoid the red sensors.",
"If you touch them...",
"The mission will be compromised.",
"You have five minutes to break in.",
"Failure to do so will get us caught.",
"Don't let us down."
]
