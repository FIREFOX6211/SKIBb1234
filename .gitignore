game.onUpdateInterval(100, function () {
    if (countdown_exists) {
        if (bounceWall1.vy == 0) {
            bounceVelocity1 = bounceVelocity1 * -1
            bounceWall1.setVelocity(0, bounceVelocity1)
        }
        if (bounceWall2.vy == 0) {
            bounceVelocity2 = bounceVelocity2 * -1
            bounceWall2.setVelocity(0, bounceVelocity2)
        }
    }
})
