controller.A.onEvent(ControllerButtonEvent.Pressed, function () {
    if (index >= text_list.length) {
        if (!(countdown_exists)) {
            playGame()
        } else {
            if (SwitchingtoSwitch1 == 0 && CHARACTER_2.vy == 0 && SwitchingtoSwitch3 == 0) {
                CHARACTER_2.vy = -70
            }
        }
    } else {
        if (BEGINNING_TEXT) {
            BEGINNING_TEXT.setText(text_list[index])
            if (text_list[index] == text_list[0]) {
                animation.stopAnimation(animation.AnimationTypes.All, Box)
                Box.setImage(img`
